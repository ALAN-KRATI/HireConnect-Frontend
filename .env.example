# Frontend environment — copy this file to .env before building.
#
# API base URL is hard-coded to http://localhost:8080 in src/config/api.config.js
# (that's the API gateway exposed by docker-compose).  VITE_API_URL below is
# only used for OAuth redirect URLs.
VITE_API_URL=http://localhost:8080

# Stripe publishable key.  If you leave this unset the Payment page shows a
# helpful "Stripe is not configured" message instead of crashing the JS SDK.
# Drop in a real pk_test_* key to enable the checkout flow end-to-end.
VITE_STRIPE_PUBLISHABLE_KEY=
